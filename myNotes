# ==========================================================
# LECTURE 2 : OPERATORS & CONDITIONAL STATEMENTS
# ==========================================================


# ----------------------------------------------------------
# 7. ARITHMETIC OPERATORS
# ----------------------------------------------------------

a = 10
b = 3

print(a + b)   # addition
print(a - b)   # subtraction
print(a * b)   # multiplication
print(a / b)   # division
print(a % b)   # remainder
print(a ** b)  # power


# ----------------------------------------------------------
# 8. RELATIONAL (COMPARISON) OPERATORS
# ----------------------------------------------------------

print(a == b)
print(a != b)
print(a > b)
print(a < b)
print(a >= b)
print(a <= b)


# ----------------------------------------------------------
# 9. ASSIGNMENT OPERATORS
# ----------------------------------------------------------

x = 5
x += 2
print(x)

x -= 1
print(x)


# ----------------------------------------------------------
# 10. LOGICAL OPERATORS
# ----------------------------------------------------------

print(True and False)
print(True or False)
print(not True)


# ----------------------------------------------------------
# 11. TYPE CONVERSION
# ----------------------------------------------------------

a = 2
b = 4.25

sum1 = a + b
print(sum1)   # automatic conversion


# Type casting
a = int("5")
print(a)


# ----------------------------------------------------------
# 12. CONDITIONAL STATEMENTS
# ----------------------------------------------------------

age = 18

if age >= 18:
    print("You can vote")


# ----------------------------------------------------------
# IF - ELSE
# ----------------------------------------------------------

num = 7

if num % 2 == 0:
    print("Even")
else:
    print("Odd")


# ----------------------------------------------------------
# IF - ELIF - ELSE
# ----------------------------------------------------------

marks = 85

if marks >= 90:
    print("Grade A")
elif marks >= 75:
    print("Grade B")
else:
    print("Grade C")


# ----------------------------------------------------------
# NESTED IF
# ----------------------------------------------------------

num = 10

if num > 0:
    if num % 2 == 0:
        print("Positive Even Number")


